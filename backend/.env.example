# ===== 应用配置 =====
APP_NAME=LOL Tracker
DEBUG=false

# ===== Riot API（国服） =====
# 国服代理地址
RIOT_GATEWAY_URL=https://api.riot-gateway.cn
# Riot API Key（可选，某些接口需要）
RIOT_API_KEY=

# ===== OP.GG API =====
OPGG_API_URL=https://api.op.gg
# OP.GG API Key（可选）
OPGG_API_KEY=

# ===== 缓存（可选） =====
# Redis 连接字符串，留空则使用内存缓存
# REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# ===== 限流 =====
RATE_LIMIT_PER_SECOND=20
RATE_LIMIT_PER_MINUTE=100

# ===== CORS =====
# 前端域名，多个用逗号分隔，开发环境用 * 即可
CORS_ORIGINS=*
